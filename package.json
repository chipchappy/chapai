{
  "name": "chapai",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "node --test --import tsx scripts/__tests__/*.test.ts",
    "typecheck": "npm run type-check",
    "type-check": "npm run type-check --workspace=@chapai/web",
    "rewrite:distractors": "node scripts/rewrite-distractor-rationales.mjs",
    "retag:question-types": "node scripts/retag-question-types.mjs",
    "d1:migrate:p1:staging": "node scripts/apply-d1-p1-ngn-migration.mjs --database=chapai-staging --remote --config=wrangler.staging.jsonc",
    "d1:migrate:p1:prod": "node scripts/apply-d1-p1-ngn-migration.mjs --database=chapai-prod --remote --config=wrangler.jsonc",
    "d1:sync:p1:staging": "node scripts/sync-d1-question-bank.mjs --database=chapai-staging --remote --config=wrangler.staging.jsonc --only-p1",
    "d1:sync:p1:prod": "node scripts/sync-d1-question-bank.mjs --database=chapai-prod --remote --config=wrangler.jsonc --only-p1",
    "deploy": "turbo deploy"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.22.3"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.29.2"
  }
}
