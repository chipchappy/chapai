{
  "name": "chapai",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "npm run type-check --workspace=@chapai/web",
    "agent:audit": "node scripts/audit-agent-capabilities.mjs --repair",
    "agent:audit:dry": "node scripts/audit-agent-capabilities.mjs --dry-run",
    "agent:health": "node scripts/ops/assert-agent-supervision-health.mjs",
    "agent:supervisor": "node scripts/ops/chapai-agent-supervisor.mjs",
    "agent:watchdog": "node scripts/ops/chapai-watchdog.mjs",
    "agent:watchdog:dry": "node scripts/ops/chapai-watchdog.mjs --dry-run",
    "content:review:nclex": "node scripts/review-nclex-candidate-bank.mjs",
    "deploy": "turbo deploy"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0"
  }
}
