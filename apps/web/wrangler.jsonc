{
  "name": "chapai-web",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "chapai-prod",
      // After creating: npx wrangler d1 create chapai-prod
      "database_id": "e8715985-6b8f-47d7-99c1-22c211286528"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "d159ff5c9837436ea549d0bfc39682c5"
      // After creating: npx wrangler kv namespace create chapai-kv
    }
  ],
  "vars": {
    "NEXTAUTH_URL": "https://chapaisolutions.com",
    "NEXT_PUBLIC_APP_URL": "https://chapaisolutions.com",
    "APP_ENV": "production",
    "DEMO_MODE": "false",
    "OPENROUTER_MODEL": "openrouter/auto"
  }
  // Custom domains added in Cloudflare Dashboard:
  // Workers & Pages → chapai-web → Settings → Triggers → Add custom domain
  // → chapaisolutions.com, www.chapaisolutions.com
}
