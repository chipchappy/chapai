{
  "name": "chapai-web",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".open-next/worker-with-cron.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "chapai-prod",
      // After creating: npx wrangler d1 create chapai-prod
      "database_id": "e8715985-6b8f-47d7-99c1-22c211286528"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "d159ff5c9837436ea549d0bfc39682c5"
      // After creating: npx wrangler kv namespace create chapai-kv
    }
  ],
  // Cloudflare Workers AI — free allocation (10k Neurons/day), no API key.
  // Powers the live AI tutor and the deep-rationale authoring route.
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "NEXTAUTH_URL": "https://claritynclex.com",
    "NEXT_PUBLIC_APP_URL": "https://claritynclex.com",
    "NEXT_PUBLIC_SUPABASE_URL": "https://gciwxmfbradcebxnthos.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdjaXd4bWZicmFkY2VieG50aG9zIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU1ODM0NTcsImV4cCI6MjA5MTE1OTQ1N30.EEZiJFxt-cG-xzU7ej0-q9kT0WfFk7iogGBvILD84EY",
    "APP_ENV": "production",
    "DEMO_MODE": "false",
    "NEXT_PUBLIC_GA_MEASUREMENT_ID": "G-NT7C6FL4J1",
    "OPENROUTER_MODEL": "openrouter/auto",
    "WORKERS_AI_MODEL": "@cf/meta/llama-3.1-8b-instruct",
    "STRIPE_PRICE_TRIAL_7DAY": "price_1TIWiWANUEeCGFKSm1MZaiSh",
    "STRIPE_PRICE_PLUS_MONTHLY": "price_1TIWiXANUEeCGFKSshU1NHDz",
    "STRIPE_PRICE_PRO_MONTHLY": "price_1TIWiYANUEeCGFKS8dudVUuj"
  },
  "routes": [
    { "pattern": "claritynclex.com", "custom_domain": true },
    { "pattern": "www.claritynclex.com", "custom_domain": true },
    { "pattern": "clarityccrn.chapaisolutions.com", "custom_domain": true },
    { "pattern": "clarityhome.chapaisolutions.com", "custom_domain": true },
    { "pattern": "claritynclex.chapaisolutions.com", "custom_domain": true }
  ],
  // Cron triggers — see scripts/inject-scheduled.cjs CRON_ROUTES for routing.
  //   0 12 * * *  → 7am ET → /api/cron/qotd-send (daily question email)
  //   0 13 * * *  → 8am ET → /api/cron/streak-protection
  "triggers": {
    "crons": ["0 12 * * *", "0 13 * * *", "*/15 * * * *"]
  }
}
