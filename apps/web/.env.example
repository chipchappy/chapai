# ─── ChapAI Environment Variables ────────────────────────────────────────────
# Copy to .env.local for local dev. Never commit real values.
# Production/staging values are set via: npx wrangler secret put SECRET_NAME

# App
NEXTAUTH_URL=https://chapaisolutions.com
NEXT_PUBLIC_APP_URL=https://chapaisolutions.com
APP_ENV=production          # "production" | "staging"
DEMO_MODE=false             # "true" unlocks all features, bypasses AI cost

# Auth
AUTH_SECRET=                # openssl rand -base64 32

# Stripe (use sk_test_... for local/staging, sk_live_... for prod)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI Tutor — OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto   # free tier: "openrouter/auto" or a specific free model

# Optional
TELEGRAM_BOT_TOKEN=
