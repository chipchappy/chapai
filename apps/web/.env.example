# ChapAI environment variables
# Copy to .env.local for local development. Never commit real values.
# Hosted production values belong in deployment platform secrets.

# App
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development
DEMO_MODE=false
DEMO_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth
AUTH_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_NCLEX_24H=
STRIPE_PRICE_CCRN_24H=
STRIPE_PRICE_NCLEX_BASE_MONTHLY=
STRIPE_PRICE_CCRN_BASE_MONTHLY=
STRIPE_PRICE_ALL_ACCESS_MONTHLY=
STRIPE_PRICE_NCLEX_4DAY=
STRIPE_PRICE_CCRN_4DAY=
STRIPE_PRICE_CORE_MONTHLY=
STRIPE_PRICE_TRIAL_7DAY=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# AI tutor
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# Monitoring / analytics
